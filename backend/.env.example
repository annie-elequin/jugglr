PORT=3000
NODE_ENV=production

# PostgreSQL connection string from Railway (or any Postgres provider)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# The public URL of this backend service (set to your Railway deployment URL)
BACKEND_URL="https://your-service.up.railway.app"

# Optional: OpenAI API key if using AI features
OPENAI_API_KEY=""
